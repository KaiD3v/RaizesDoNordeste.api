# Copie este arquivo para .env e ajuste os valores:
# cp .env.example .env

# PostgreSQL (aplicação Spring Boot)
DB_URL=jdbc:postgresql://localhost:5432/raizes
DB_USER=raizes
DB_PASSWORD=change-me

# PostgreSQL (Docker Compose)
POSTGRES_DB=raizes
POSTGRES_USER=raizes
POSTGRES_PASSWORD=change-me

# JWT (mínimo 32 caracteres)
JWT_SECRET=change-me-use-a-long-random-string-min-32-chars
JWT_EXPIRATION_MS=86400000

# Servidor
SERVER_PORT=8080
