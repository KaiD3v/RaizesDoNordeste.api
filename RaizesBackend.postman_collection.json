{
  "info": {
    "name": "Raízes do Nordeste API",
    "description": "Coleção de testes para a API Raízes do Nordeste",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "pedidoId",
      "value": ""
    },
    {
      "key": "unidadeId",
      "value": "11111111-1111-1111-1111-111111111101"
    },
    {
      "key": "produtoId",
      "value": "33333333-3333-3333-3333-333333333301"
    }
  ],
  "item": [
    {
      "name": "1. Registrar usuário (sucesso)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Cliente Teste\",\n  \"email\": \"cliente.teste@email.com\",\n  \"senha\": \"123456\",\n  \"consentimentoLGPD\": true\n}"
        },
        "url": "{{baseUrl}}/auth/register"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Login (sucesso)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"cliente.teste@email.com\",\n  \"senha\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Listar pedidos sem token (401)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/pedidos"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Criar pedido canal válido (201)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"canalPedido\": \"APP\",\n  \"itens\": [\n    { \"produtoId\": \"{{produtoId}}\", \"quantidade\": 1 }\n  ],\n  \"formaPagamento\": \"MOCK\"\n}"
        },
        "url": "{{baseUrl}}/pedidos"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('pedidoId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Criar pedido canal inválido (422)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"canalPedido\": \"INVALIDO\",\n  \"itens\": [\n    { \"produtoId\": \"{{produtoId}}\", \"quantidade\": 1 }\n  ],\n  \"formaPagamento\": \"MOCK\"\n}"
        },
        "url": "{{baseUrl}}/pedidos"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 422', function () {",
              "    pm.response.to.have.status(422);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Criar pedido sem estoque (409)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"unidadeId\": \"{{unidadeId}}\",\n  \"canalPedido\": \"APP\",\n  \"itens\": [\n    { \"produtoId\": \"{{produtoId}}\", \"quantidade\": 9999 }\n  ],\n  \"formaPagamento\": \"MOCK\"\n}"
        },
        "url": "{{baseUrl}}/pedidos"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 409', function () {",
              "    pm.response.to.have.status(409);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Simular pagamento aprovado (200)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pedidoId\": \"{{pedidoId}}\",\n  \"numeroCartaoMock\": \"4111111111111112\"\n}"
        },
        "url": "{{baseUrl}}/pagamentos/simular"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Pagamento aprovado', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('APROVADO');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "8. Simular pagamento recusado (cartão 1111)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pedidoId\": \"{{pedidoId}}\",\n  \"numeroCartaoMock\": \"4111111111111111\"\n}"
        },
        "url": "{{baseUrl}}/pagamentos/simular"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Pagamento recusado', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('RECUSADO');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "9. Login cozinha",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"cozinha@raizes.com\",\n  \"senha\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "10. Atualizar status cozinha (200)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"PRONTO\"\n}"
        },
        "url": "{{baseUrl}}/pedidos/{{pedidoId}}/status"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "11. Login cliente e atualizar status (403)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"cliente.teste@email.com\",\n  \"senha\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "12. Tentar atualizar status como cliente (403)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"ENTREGUE\"\n}"
        },
        "url": "{{baseUrl}}/pedidos/{{pedidoId}}/status"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 403', function () {",
              "    pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
